<?xml version="1.0" encoding="utf-8"?><!--
   Sample data extraction rules file; uncomment and customize as necessary.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes
   for details.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude DataStore settings (nyimpen Gemini API key user) dari cloud backup,
             supaya gak ikut ke-backup ke Google Drive lewat Auto Backup Android. -->
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <!-- Sama juga untuk transfer perangkat-ke-perangkat (mis. setup HP baru). -->
        <exclude domain="file" path="datastore/settings.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
